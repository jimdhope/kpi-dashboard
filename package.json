{
  "name": "kpi-quest",
  "version": "3.6.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 9103",
    "dev:metrics": "ENABLE_RUNTIME_METRICS=true next dev -p 9103",
    "dev:inspect": "NODE_OPTIONS=--inspect next dev -p 9103",
    "build": "next build",
    "build:memory": "next build --experimental-debug-memory-usage",
    "analyze": "next experimental-analyze --output",
    "start": "next start -p 9103",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test:permissions": "node --import tsx/esm --test src/server/security/authorization-policy.test.ts",
    "test:unit": "node --import tsx/esm --test src/server/security/authorization-policy.test.ts src/server/http-pagination.test.ts",
    "jobs:work": "tsx --env-file=.env src/server/jobs/worker.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node --import tsx/esm prisma/seed.ts",
    "auth:cutover": "node --import tsx/esm scripts/auth-cutover.ts",
    "db:studio": "prisma studio"
  },
