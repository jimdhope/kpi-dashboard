generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum RoleKey {
  admin
  campaignManager
  podManager
  teamLeader
  competitionRunner
  agent
}

enum AwardScope {
  COMPETITION
  MONTHLY
  YEARLY
  MANUAL
}

enum TeamsWebhookDirection {
  incoming
  outgoing
}

enum TeamsChannelCategory {
  daily_summary
  leaderboard
  alert
  campaign
  custom
}

enum TeamsAutomationTrigger {
  incomingWebhookReceived
  performanceLogged
  competitionScoreLogged
}

enum TeamsAutomationScope {
  global
  campaign
  pod
}

enum TeamsAutomationMode {
  event
  oneTime
  recurring
}

enum TeamsAutomationConditionEvent {
  performanceLogged
  competitionScoreLogged
}

enum TeamsAutomationConditionMetric {
  count
  totalValue
}

enum TeamsAutomationDeliveryFormat {
  messageCard
  adaptiveCard
  adaptiveCardWithImage
}

enum KpiType {
  number
  percentage
  scoreOutOf
}

enum ScoreTargetType {
  competition
  tracker
}

enum KpiSortOrder {
  desc
  asc
}

enum PassFailOperator {
  gte
  lte
}

model Kpi {
  id                    String            @id @default(cuid())
  name                  String
  initials              String            @db.VarChar(4)
  type                  KpiType           @default(number)
  maxValue              Decimal?
  sortOrder             KpiSortOrder      @default(desc)
  passFailCriteriaEnabled Boolean          @default(false)
  passFailOperator       PassFailOperator?
  passFailValue         Decimal?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  kpiLogs               KpiLog[]
}

model KpiLog {
  id        String   @id @default(cuid())
  kpiId     String
  userId    String?
  value     Decimal
  date      DateTime  // When the KPI was achieved/recorded (from Firebase)
  loggedAt  DateTime @default(now()) // When it was imported
  createdAt DateTime @default(now())
  kpi       Kpi     @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([kpiId])
  @@index([userId])
  @@index([loggedAt])
  @@index([date])
  @@index([userId, date])
  @@index([kpiId, userId, date])
}

model User {
  id                    String                     @id @default(cuid())
  email                 String                     @unique
  name                  String
  emailVerified         Boolean                    @default(true)
  avatarUrl             String?
  avatarInitials        String?
  avatarBgColor         String?
  firebaseUid           String?                    @unique
  mustChangePassword    Boolean                   @default(false)
  podId                 String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  userRoles             UserRole[]
  sessions              Session[]
  accounts              Account[]
  passkeys              Passkey[]
  auditLogs             AuditLog[]
  podMemberships        PodMembership[]
  trackerLogs           TrackerLog[]
  kpiLogs               KpiLog[]
  competitionEntries    CompetitionEntry[]
  createdCompetitions   Competition[]
  activities            Activity[]
  pod                   Pod?                       @relation(fields: [podId], references: [id])
  ledPods               Pod[]                      @relation("PodTeamLeader")
  managedPods           Pod[]                      @relation("PodManager")
  
  // Knowledge Base relations
  kbArticles            KBArticle[]
  kbVersions            KBVersion[]
  kbComments            KBComment[]
  
  // Directory relations
  createdContacts        Contact[]
  createdCompanies       Company[]

  // Gamification relations
  totalPoints           Int                       @default(0)
  badges                AgentBadge[]
  competitionResults    CompetitionResult[]
  dailyGameAttempts     DailyGameAttempt[]
  notifications         Notification[]
}

model Role {
  id          String           @id @default(cuid())
  key         RoleKey          @unique
  name        String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userRoles   UserRole[]
  permissions RolePermission[]
  dataScopes  RoleDataScope[]
}

enum PermissionLevel {
  NONE
  VIEW
  MANAGE
}

enum NotificationType {
  FEEDBACK_SUBMITTED
  FEEDBACK_REPLIED
  SCORE_CORRECTED
  RESULT_CONFIRMED
  ANNOUNCEMENT
}

model RolePermission {
  id       String          @id @default(cuid())
  roleId   String
  role     Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  resource String
  level    PermissionLevel @default(NONE)

  @@unique([roleId, resource])
}

enum DataScopeLevel {
  NONE
  ASSIGNED_PODS
  ALL_PODS
}

model RoleDataScope {
  id       String         @id @default(cuid())
  roleId   String
  role     Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)
  resource String
  level    DataScopeLevel @default(NONE)

  @@unique([roleId, resource])
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                     String    @id @default(cuid())
  accountId              String
  providerId             String
  userId                 String
  accessToken            String?
  refreshToken           String?
  idToken                String?
  accessTokenExpiresAt   DateTime?
  refreshTokenExpiresAt  DateTime?
  scope                  String?
  password               String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

model Passkey {
  id           String   @id @default(cuid())
  name         String?
  publicKey    String
  userId       String
  credentialID String   @unique
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  createdAt    DateTime @default(now())
  aaguid       String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RateLimit {
  id          String @id @default(cuid())
  key         String @unique
  count       Int
  lastRequest BigInt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  payloadJson Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Campaign {
  id                String                @id @default(cuid())
  name              String
  description       String?
  isActive          Boolean               @default(true)
  incomingWebhookId String?
  outgoingWebhookId String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  incomingWebhook   TeamsWebhookEndpoint? @relation("CampaignIncomingWebhook", fields: [incomingWebhookId], references: [id], onDelete: SetNull)
  outgoingWebhook   TeamsWebhookEndpoint? @relation("CampaignOutgoingWebhook", fields: [outgoingWebhookId], references: [id], onDelete: SetNull)
  teamsAutomations  TeamsAutomation[]
  pods              Pod[]
  trackerKpis       TrackerKpi[]
  competitions      Competition[]
}

model Pod {
  id                String                @id @default(cuid())
  campaignId        String?
  incomingWebhookId String?
  outgoingWebhookId String?
  name              String
  description       String?
  teamLeaderId      String?
  podManagerId      String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  campaign          Campaign?             @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  incomingWebhook   TeamsWebhookEndpoint? @relation("PodIncomingWebhook", fields: [incomingWebhookId], references: [id], onDelete: SetNull)
  outgoingWebhook   TeamsWebhookEndpoint? @relation("PodOutgoingWebhook", fields: [outgoingWebhookId], references: [id], onDelete: SetNull)
  teamLeader        User?                 @relation("PodTeamLeader", fields: [teamLeaderId], references: [id])
  podManager        User?                 @relation("PodManager", fields: [podManagerId], references: [id])
  teamsAutomations  TeamsAutomation[]
  memberships       PodMembership[]
  users             User[]
}

model PodMembership {
  id        String   @id @default(cuid())
  podId      String
  userId     String
  joinedAt   DateTime @default(now())
  pod        Pod      @relation(fields: [podId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([podId, userId])
}

model TrackerKpi {
  id          String       @id @default(cuid())
  campaignId  String?
  name        String
  unit        String?
  targetValue Decimal?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  campaign    Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  logs        TrackerLog[]
}

model TrackerLog {
  id           String    @id @default(cuid())
  trackerKpiId String
  userId       String?
  value        Decimal
  loggedAt     DateTime  @default(now())
  createdAt    DateTime  @default(now())
  trackerKpi   TrackerKpi @relation(fields: [trackerKpiId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Competition {
  id            String             @id @default(cuid())
  name          String
  description   String?
  startsAt      DateTime?
  endsAt        DateTime?
  campaignId    String?
  podIds        String[]
  isDraft       Boolean            @default(false)
  autoTeamsUpdates Boolean          @default(false)
  lastAutoTeamsScoreAt DateTime?
  lastAutoTeamsSentAt DateTime?
  draftData     Json?
  createdById   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  rules         CompetitionRule[]
  teams         CompetitionTeam[]
  entries       CompetitionEntry[]
  createdBy     User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  campaign      Campaign?          @relation(fields: [campaignId], references: [id])
  results       CompetitionResult[]
  resultConfirmation CompetitionResultConfirmation?
  agentBadges   AgentBadge[]

  @@index([startsAt, endsAt])
  @@index([isDraft, createdAt])
}

model CompetitionResult {
  id            String      @id @default(cuid())
  userId        String
  competitionId String
  rank          Int
  totalScore    Int
  xpEarned      Int         @default(0)
  wasPresent    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@unique([userId, competitionId])
  @@index([userId])
  @@index([competitionId])
}

model CompetitionResultConfirmation {
  id            String      @id @default(cuid())
  competitionId String      @unique
  confirmedById String
  note          String?
  confirmedAt   DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([confirmedAt])
}

model CompetitionRule {
  id            String      @id @default(cuid())
  competitionId  String
  title         String
  points        Int         @default(0)
  isCheckbox    Boolean     @default(false)
  agentCanLog   Boolean     @default(false)
  emoji         String?
  dailyTarget   Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
}

model CompetitionTeam {
  id            String      @id @default(cuid())
  competitionId String
  name          String
  agentIds      String[]    @default([])
  emoji         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
}

model CompetitionEntry {
  id            String      @id @default(cuid())
  competitionId  String
  userId        String?
  score         Int         @default(0)
  present       Boolean     @default(false)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  scoreLogs     CompetitionScoreLog[]

  @@index([competitionId])
  @@index([userId])
  @@index([competitionId, userId])
  @@index([competitionId, score])
}

model CompetitionScoreLog {
  id            String            @id @default(cuid())
  entryId       String
  ruleId        String?
  value         Int               @default(0)
  isBonus       Boolean           @default(false)
  bonusTeamId   String?
  loggedAt      DateTime          @default(now())
  createdAt     DateTime          @default(now())
  entry         CompetitionEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId, loggedAt])
  @@index([ruleId, entryId])
}

model CompetitionRuleTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  rules       Json    // Array of rule definitions: { title, points, isCheckbox, emoji, dailyTarget }
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MessageOfDay {
  id          String   @id @default(cuid())
  title       String
  message     String
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, expiresAt])
}

model Feedback {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  message     String
  status      String   @default("NEW")
  staffReply  String?
  repliedAt   DateTime?
  repliedById String?
  attachments Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model Absence {
  id          String   @id @default(cuid())
  userId      String
  startsOn    DateTime
  endsOn      DateTime?
  reason      String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, startsOn, endsOn])
}

model AbsencePresenceOverride {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  createdById String
  createdAt   DateTime @default(now())

  @@unique([userId, date])
  @@index([date])
}

model Activity {
  id           String   @id @default(cuid())
  userId       String?
  type         String
  title        String
  description  String?
  metadataJson Json?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Enhanced fields
  agentName    String?
  recorderId   String?
  recorderName String?
  richMessage  String?

  @@index([userId, createdAt])
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  type        NotificationType
  title       String
  message     String
  href        String?
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  recipient   User             @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, readAt, createdAt])
}

model TeamsWebhookEndpoint {
  id                   String                @id @default(cuid())
  name                 String
  friendlyName        String?
  direction            TeamsWebhookDirection
  url                  String
  description          String?
  category            TeamsChannelCategory?
  testStatus          String?               @default("untested") // untested, success, failed
  lastTestedAt        DateTime?
  lastPostAt         DateTime?
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  campaignIncomingRefs Campaign[]            @relation("CampaignIncomingWebhook")
  campaignOutgoingRefs Campaign[]            @relation("CampaignOutgoingWebhook")
  podIncomingRefs      Pod[]                 @relation("PodIncomingWebhook")
  podOutgoingRefs      Pod[]                 @relation("PodOutgoingWebhook")
  outgoingAutomations  TeamsAutomation[]     @relation("TeamsAutomationOutgoingWebhook")
  inboundEvents        TeamsIncomingEvent[]
}

model TeamsAutomation {
  id                String                 @id @default(cuid())
  name              String
  trigger           TeamsAutomationTrigger
  scope             TeamsAutomationScope   @default(global)
  mode              TeamsAutomationMode    @default(event)
  deliveryFormat    TeamsAutomationDeliveryFormat @default(messageCard)
  messageTemplateId String?
  campaignId        String?
  podId             String?
  outgoingWebhookId String
  titleTemplate     String
  messageTemplate   String
  factsJson         Json?
  adaptiveCardJson  Json?
  imageTitleTemplate String?
  imageSubtitleTemplate String?
  imageMetricTemplate String?
  imageFooterTemplate String?
  imageAccentColor  String?
  oneTimeAt         DateTime?
  startsAt          DateTime?
  endsAt            DateTime?
  timezone          String?               @default("UTC")
  windowStartTime   String?
  windowEndTime     String?
  quietStartTime    String?
  quietEndTime      String?
  repeatEveryMinutes Int?
  batchWindowMinutes Int?
  cooldownMinutes   Int?
  conditionEvent    TeamsAutomationConditionEvent?
  conditionMetric   TeamsAutomationConditionMetric?
  conditionLookbackMinutes Int?
  conditionMinimumCount Int?
  conditionMinimumValue Float?
  onlyIfNewData     Boolean                @default(false)
  conditionActivityWithinMinutes Int?
  isActive          Boolean                @default(true)
  lastTriggeredAt   DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  campaign          Campaign?              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  pod               Pod?                   @relation(fields: [podId], references: [id], onDelete: Cascade)
  outgoingWebhook   TeamsWebhookEndpoint   @relation("TeamsAutomationOutgoingWebhook", fields: [outgoingWebhookId], references: [id], onDelete: Cascade)
  messageTemplateRef TeamsMessageTemplate? @relation(fields: [messageTemplateId], references: [id], onDelete: SetNull)
  pendingDeliveries TeamsAutomationPendingDelivery[]

  @@index([trigger, scope, isActive])
}

model TeamsMessageTemplate {
  id                   String                        @id @default(cuid())
  name                 String
  category             TeamsChannelCategory?
  version              Int                           @default(1)
  deliveryFormat       TeamsAutomationDeliveryFormat @default(messageCard)
  titleTemplate        String
  messageTemplate      String
  factsJson            Json?
  adaptiveCardJson     Json?
  imageTitleTemplate   String?
  imageSubtitleTemplate String?
  imageMetricTemplate  String?
  imageFooterTemplate  String?
  imageAccentColor     String?
  variationsJson       Json?                        // { compact: {...}, detailed: {...}, celebration: {...} }
  isDefault            Boolean                      @default(false)
  isActive             Boolean                       @default(true)
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  automations          TeamsAutomation[]
}

model TeamsAutomationPendingDelivery {
  id           String          @id @default(cuid())
  automationId String
  title        String
  text         String
  factsJson    Json?
  dueAt        DateTime
  createdAt    DateTime        @default(now())
  sentAt       DateTime?
  automation   TeamsAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId, dueAt, sentAt])
}

model TeamsIncomingEvent {
  id           String               @id @default(cuid())
  endpointId   String
  endpointName String
  payloadJson  Json
  headersJson  Json?
  createdAt    DateTime             @default(now())
  endpoint     TeamsWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, createdAt])
}

model ScoreTarget {
  id           String           @id @default(cuid())
  hashtag      String           @unique
  name         String
  targetType   ScoreTargetType
  competitionId String?
  trackerKpiId String?
  defaultPoints Int            @default(1)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([hashtag])
}

// =============================================================================
// Gamification Models
// =============================================================================

model Badge {
  id          String     @id @default(cuid())
  key         String     @unique
  name        String
  description String?
  icon        String?
  iconType    String?    @default("emoji")
  scope       AwardScope @default(COMPETITION)
  criteria    Json?
  rankTinted  Boolean    @default(false)
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  agentBadges AgentBadge[]
}

model AgentBadge {
  id              String       @id @default(cuid())
  userId          String
  badgeId         String
  competitionId   String?
  context         Json?
  earnedAt        DateTime     @default(now())
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge           Badge        @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  competition     Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  
  @@unique([userId, badgeId, competitionId])
  @@index([competitionId])
}


// =============================================================================
// V2 Firebase Migration Models
// =============================================================================

model DailyAchievement {
  id             String    @id @default(cuid())
  competitionId  String
  agentId        String
  podId          String
  ruleId         String
  ruleName       String?
  value          Int       @default(0)
  points         Int       @default(0)
  date           DateTime
  loggedBy       String?
  loggedAt       DateTime?
  createdAt      DateTime  @default(now())

  @@index([competitionId])
  @@index([agentId])
  @@index([podId])
  @@index([date])
}

model DailyTaskLog {
  id             String    @id @default(cuid())
  competitionId  String
  agentId        String
  podId          String?
  taskId         String
  taskName       String?
  completed      Boolean   @default(false)
  date           DateTime
  createdAt      DateTime  @default(now())

  @@index([competitionId])
  @@index([agentId])
  @@index([date])
}

// Canonical, append-only record of a competition scoring action. This model is
// additive while legacy score stores are reconciled and remains intentionally
// decoupled from cascading relations so historic audit evidence is preserved.
model ScoreEvent {
  id                 String   @id @default(cuid())
  competitionId      String
  ruleId             String
  ruleName           String?
  subjectAgentId     String
  podId              String
  quantity           Int
  points             Int
  scoredForDate      DateTime
  source             String
  recordedAt         DateTime?
  recordedById       String?
  idempotencyKey     String?  @unique
  externalReference  String?
  correctionOfId     String?
  voidedAt           DateTime?
  voidedById         String?
  voidReason         String?
  createdAt          DateTime @default(now())

  @@index([competitionId, scoredForDate])
  @@index([competitionId, subjectAgentId])
  @@index([subjectAgentId, scoredForDate])
  @@index([ruleId, scoredForDate])
  @@index([correctionOfId])
  @@index([externalReference])
}

model TeamBonusLog {
  id             String    @id @default(cuid())
  competitionId  String
  teamId         String
  teamName       String?
  podId          String?
  points         Int       @default(0)
  reason         String?
  date           DateTime
  loggedBy       String?
  loggedAt       DateTime?
  createdAt      DateTime  @default(now())

  @@index([competitionId])
  @@index([teamId])
  @@index([podId])
  @@index([date])
}

model PodTarget {
  id             String   @id @default(cuid())
  competitionId  String
  podId          String
  date           DateTime
  targetsJson    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([competitionId, podId, date])
  @@index([competitionId])
  @@index([podId])
}

model RpsGame {
  id             String   @id @default(cuid())
  playerId       String
  playerThrow    String
  opponentThrow  String
  result         String
  points         Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([playerId, createdAt])
}

model DailyGameChallenge {
  id            String             @id @default(cuid())
  gameKey       String
  challengeDate String
  variant       String             @default("default")
  content       Json
  solution      Json
  createdAt     DateTime           @default(now())
  attempts      DailyGameAttempt[]

  @@unique([gameKey, challengeDate, variant])
  @@index([challengeDate])
}

model DailyGameAttempt {
  id          String             @id @default(cuid())
  challengeId String
  userId      String
  status      String             @default("in_progress")
  score       Int                @default(0)
  durationMs  Int?
  guesses     Int?
  mistakes    Int                @default(0)
  hints       Int                @default(0)
  state       Json
  metrics     Json?
  startedAt   DateTime           @default(now())
  completedAt DateTime?
  updatedAt   DateTime           @updatedAt
  challenge   DailyGameChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([challengeId, status, score])
  @@index([userId, startedAt])
}

model ImportLog {
  id            String   @id @default(cuid())
  importedAt    DateTime @default(now())
  source        String   // "upload" or "existing"
  collections   Json     // { "users": { imported: 48, updated: 5 }, ... }
  durationMs    Int
  status        String   // "success", "partial", "failed"
  errorMessage  String?
}

// =============================================================================
// Shared Tags System
// =============================================================================

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  kbArticles KBArticle[]
  contacts   Contact[]
  
  @@index([name])
}

// =============================================================================
// Knowledge Base
// =============================================================================

model KBCategory {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  parentId  String?
  parent    KBCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  KBCategory[] @relation("CategoryHierarchy")
  articles  KBArticle[]
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  
  @@index([slug])
  @@index([parentId])
}

model KBArticle {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  content     Json        // Tiptap JSON
  excerpt     String?     // Short preview
  categoryId  String?
  category    KBCategory? @relation(fields: [categoryId], references: [id])
  locked      Boolean     @default(false)
  lockedRoles String[]    @default([]) // Roles that cannot edit
  status      String      @default("draft") // draft, published
  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  publishedAt DateTime?
  views       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  versions    KBVersion[]
  comments    KBComment[]
  tags        Tag[]
  
  @@index([slug])
  @@index([status])
  @@index([categoryId])
  @@index([createdById])
}

model KBVersion {
  id            String    @id @default(cuid())
  articleId     String
  article       KBArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  title         String
  content       Json
  createdById   String
  createdBy     User      @relation(fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  
  @@index([articleId])
}

model KBComment {
  id           String     @id @default(cuid())
  articleId    String
  article      KBArticle  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  content      String
  parentId     String?
  parent      KBComment?  @relation("CommentThreads", fields: [parentId], references: [id])
  replies     KBComment[] @relation("CommentThreads")
  resolved    Boolean     @default(false)
  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([articleId])
  @@index([parentId])
}

// =============================================================================
// Directory
// =============================================================================

model Company {
  id          String    @id @default(cuid())
  name        String
  type        String    @default("external") // internal, external
  email       String?
  phone       String?
  website     String?
  address     String?
  notes       String?
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([name])
  @@index([type])
}

model Department {
  id        String    @id @default(cuid())
  name      String    @unique
  email     String?
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Contact {
  id           String     @id @default(cuid())
  name         String
  type         String     @default("person") // person, department, team, company
  email        String?
  phone        String?
  website      String?
  address      String?
  notes        String?
  companyName  String?    // Plain text company name
  departmentName String?   // Plain text department name
  createdById  String?
  createdBy    User?      @relation(fields: [createdById], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  tags         Tag[]
  
  @@index([name])
  @@index([type])
}
