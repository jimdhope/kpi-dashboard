DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kpi_quest_v3
BETTER_AUTH_SECRET=replace-with-a-separate-long-random-secret
BETTER_AUTH_URL=http://localhost:9103
PASSKEY_RP_ID=localhost
PUBLIC_URL=http://localhost:9103
# One-time Better Auth migration only. Leave disabled and the temporary values
# unset during normal starts; remove all three after a successful cutover.
RUN_AUTH_CUTOVER=false
# CUTOVER_ADMIN_EMAIL=admin@example.com
# CUTOVER_ADMIN_TEMP_PASSWORD=use-a-unique-temporary-password
# CUTOVER_RESUME=false
SEED_ADMIN_EMAIL=admin@kpiquest.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=V3 Admin
# Encryption key for sensitive data (64 hex characters / 32 bytes)
ENCRYPTION_KEY=replace-with-a-64-character-hex-string
