{
    "type": "AdaptiveCard",
    "body": [
        {
            "type": "TextBlock",
            "size": "Medium",
            "weight": "Bolder",
            "text": "${title}"
        },
        {
            "type": "TextBlock",
            "text": "${kpiKey}",
            "wrap": true,
            "separator": true
        },
        {
            "type": "TextBlock",
            "text": "${kpiTable}",
            "wrap": true,
            "separator": true
        },
        {
            "type": "TextBlock",
            "text": "${kpiTargets}",
            "wrap": true
        }
    ],
    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
    "version": "1.6"
}
