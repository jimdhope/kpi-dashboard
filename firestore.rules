rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default rule: Allow read/write access only to authenticated users.
    // This rule applies to all collections unless overridden by more specific rules below.
    // Server actions running with appropriate credentials (e.g., service account)
    // will also be covered by `request.auth != null`.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Example of more specific rules (uncomment and adapt as needed):
    /*
    // Users can only read/write their own user document
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      // Allow creation only if authenticated (might need admin check too)
      allow create: if request.auth != null;
      // Disallow deletion by default
      allow delete: if false;
    }

    // Allow authenticated users to read campaigns, pods, competitions
    match /campaigns/{campaignId} {
      allow read: if request.auth != null;
      // Allow writes only by admins (assuming an 'isAdmin' custom claim or role)
      allow write: if request.auth != null && request.auth.token.isAdmin == true;
    }

    match /pods/{podId} {
       allow read: if request.auth != null;
       allow write: if request.auth != null && request.auth.token.isAdmin == true;
       // Or allow write by pod managers/team leaders associated with the pod
       // allow write: if request.auth != null && (request.auth.token.isAdmin == true || resource.data.podManagerId == request.auth.uid || resource.data.teamLeaderId == request.auth.uid);
    }

     match /competitions/{competitionId} {
       allow read: if request.auth != null;
       allow write: if request.auth != null && request.auth.token.isAdmin == true;
    }

     match /dailyAchievements/{achievementId} {
        // Allow agents to create their own achievements
        allow create: if request.auth != null && request.resource.data.agentId == request.auth.uid;
        // Allow users to read achievements associated with their pod (for leaderboards/scores)
        allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.podId == resource.data.podId;
        // Allow admins/managers to update/delete (adjust role check as needed)
        allow update, delete: if request.auth != null && request.auth.token.isAdmin == true; // Or check for podManager/teamLeader role
     }

     match /dailyPodTargets/{targetId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.token.isAdmin == true; // Or allow managers/leaders
     }

     match /campaignRules/{campaignId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.token.isAdmin == true;
     }
     */

  }
}
