
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow read/write access to the 'campaigns' collection for any authenticated user.
    // TODO: For production, restrict write access to admins only (e.g., using custom claims).
    match /campaigns/{campaignId} {
      allow read, write: if request.auth != null;
    }

    // Default deny all other collections/paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
