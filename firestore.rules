
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow authenticated users to read/write their own user document
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }
    
    // Allow any authenticated user to read from these collections
    // This is necessary for the admin dashboard and data export features to function correctly.
    // The admin routes themselves are protected by application logic.
    match /campaigns/{campaignId} {
      allow read, write: if request.auth != null;
    }

    match /pods/{podId} {
      allow read, write: if request.auth != null;
    }

    match /competitions/{competitionId} {
      allow read, write: if request.auth != null;
    }

    match /dailyAchievements/{achievementId} {
        allow read, write: if request.auth != null;
    }

    match /dailyPodTargets/{targetId} {
        allow read, write: if request.auth != null;
    }
    
    match /dailyTaskLogs/{logId} {
        allow read, write: if request.auth != null;
    }
    
    match /teamBonusLogs/{logId} {
        allow read, write: if request.auth != null;
    }

    match /rpsGames/{gameId} {
        allow read, write: if request.auth != null;
    }
    
    match /settings/{settingId} {
       allow read, write: if request.auth != null;
    }
    
    // Allow wider read for all users for lookup purposes
    match /users/{userId} {
      allow read: if request.auth != null;
    }

    // User notifications subcollection
    // Users can only access their own notifications
    match /users/{userId}/notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null; // Allow creating (for triggers and user-initiated)
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Tracker-related collections
    match /trackerKpis/{kpiId} {
      allow read, write: if request.auth != null;
    }

    match /trackerLogs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Additional KPIs
    match /additionalKpis/{kpiId} {
      allow read, write: if request.auth != null;
    }

    // RPS (Rock Paper Scissors) games
    match /rpsGames/{gameId} {
      allow read, write: if request.auth != null;
    }

  }
}
