rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to the pods collection for the API endpoint.
    // Writes are restricted to authenticated users (and should be further restricted to admins in a real app).
    match /pods/{podId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // All other collections require an authenticated user to read or write.
    // You can refine these rules later for more granular control (e.g., only admins can write to campaigns).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
