rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read on pods for the API
    match /pods/{podId} {
      allow read: if true;
      allow write: if request.auth != null; // Only authenticated users can write
    }

    // Allow anyone to create and read RPS game results
    match /rpsGames/{gameId} {
      allow read, create: if true;
    }

    // Allow authenticated users to read user, competition, and pod data for dashboards/leaderboards
    match /users/{userId} {
      allow read: if request.auth != null;
      // Allow users to write to their own document, and admins to write to any.
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']));
    }

    match /competitions/{competitionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /campaigns/{campaignId} {
       allow read: if request.auth != null;
       allow write: if request.auth != null;
    }

    // Allow authenticated users to read achievement logs for leaderboards
    match /dailyAchievements/{achievementId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
    
    // Default authenticated access for other collections
    match /dailyTaskLogs/{logId} {
        allow read, write: if request.auth != null;
    }

    match /teamBonusLogs/{logId} {
        allow read, write: if request.auth != null;
    }
    
    match /dailyPodTargets/{targetId} {
       allow read, write: if request.auth != null;
    }
    
    match /messageOfTheDay/{messageId} {
       allow read, write: if request.auth != null;
    }

    // Default deny all other reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
