rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow unauthenticated access for the RPS game
    match /rpsGames/{gameId} {
      allow read, create: if true;
    }

    // Allow authenticated users to read/write to team bonus logs
    match /teamBonusLogs/{logId} {
        allow read, create: if request.auth != null;
    }

    // Allow public read on pods for the API
    match /pods/{podId} {
        allow read: if true;
        // Keep write access authenticated
        allow write: if request.auth != null;
    }

    // Allow anyone to read campaigns, competitions, and users for context
    // This is often needed for public leaderboards or shared data.
    // Writes should still be protected.
    match /campaigns/{campaignId} {
        allow read: if true;
        allow write: if request.auth != null;
    }
     match /users/{userId} {
        allow read: if true;
        allow write: if request.auth != null;
    }
     match /competitions/{competitionId} {
        allow read: if true;
        allow write: if request.auth != null;
    }

    // Secure all other collections by default - requires authentication
    // This rule is now last, so it only applies if no specific rule above matched.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
