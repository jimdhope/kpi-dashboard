rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // WARNING: Development/Emulator Rules Only
    // These rules allow anyone to read and write to the campaigns collection.
    // This is ONLY for local development and testing with the Firebase Emulator Suite.
    // Secure these rules properly before deploying to production by requiring
    // authentication and appropriate authorization checks (e.g., checking user roles).
    // Example Production Rule (Requires Authentication):
    // match /campaigns/{campaignId} {
    //   allow read, write: if request.auth != null; // Adjust for specific roles if needed
    // }
    match /campaigns/{campaignId} {
      allow read, write: if true; // Allow all reads/writes for local development
    }

    // Add rules for other collections here as needed, following the same
    // principle for development vs. production rules.
  }
}
