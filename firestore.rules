rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow authenticated users to read any pod document
    // Server actions initiated by authenticated users should inherit this permission.
    match /pods/{podId} {
      allow read: if request.auth != null;
      // Keep write rules potentially more restrictive (e.g., only admins/managers)
      allow write: if request.auth != null; // TODO: Refine write access (e.g., check for admin/manager role)
    }

    // Allow authenticated users to read user documents (needed for names, etc.)
    match /users/{userId} {
      allow read: if request.auth != null;
      // Allow users to update their own profile, admins/managers to update any
      // Assumes roles are stored in custom claims like request.auth.token.admin
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin', 'podManager'])); // Example check
    }

    // Allow authenticated users to read competitions
    match /competitions/{compId} {
      allow read: if request.auth != null;
      // Consider restricting write access to specific roles
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin', 'podManager']); // Example check
    }

    // Allow authenticated users to read campaign rules
     match /campaignRules/{campId} {
        allow read: if request.auth != null;
        // Consider restricting write access to specific roles
        allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin', 'podManager']); // Example check
     }

    // Rules for daily achievements
    match /dailyAchievements/{achId} {
       allow read: if request.auth != null;
       // Allow agents to write their own logs, admins/managers/leaders to write logs for their pod members (more complex rule needed for pod check)
       // Simple rule for now: allow write if authenticated
       allow write: if request.auth != null; // TODO: Refine write access based on user role and pod membership
     }

    // Rules for daily pod targets
    match /dailyPodTargets/{targetId} {
       allow read: if request.auth != null;
       // Allow write access only to specific roles (e.g., admins/managers)
       allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin', 'podManager']); // Example check
     }

    // Allow authenticated users to read campaigns
    match /campaigns/{campaignId} {
        allow read: if request.auth != null;
        // Consider restricting write access to specific roles
        allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin', 'podManager']); // Example check
    }


    // Fallback rule for any other document path not explicitly matched above.
    // It's generally safer to default to deny unless explicitly allowed.
    // Removing the broad allow rule:
    // match /{document=**} {
    //   allow read, write: if request.auth != null;
    // }
  }
}
