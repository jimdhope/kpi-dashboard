
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to any document if the user is authenticated
    match /{document=**} {
      allow read: if request.auth != null;
      // Keep write access restricted to prevent unauthorized changes
      allow write: if false; 
    }

    // More specific write rules can be added below for specific collections
    // Example: allow create, update, delete on 'users' collection for admins
    // match /users/{userId} {
    //   allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    // }
  }
}
