rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all access to prevent unintended access
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow logged-in users to read/write their own user document
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      // Allow create for anyone (e.g. for user sign up, can be tightened)
      allow create: if true; // Or more specific rules
      // Allow admins to manage all users
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    // Campaigns: Allow read for authenticated users, write for admins
    match /campaigns/{campaignId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    // Campaign Rules: Allow read for authenticated users, write for admins
    match /campaignRules/{campaignId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    // Pods: Allow read for authenticated users, write for admins
    match /pods/{podId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    // Competitions: Allow read (get and list) for authenticated users, write for admins
    match /competitions/{competitionId} {
      allow get: if request.auth != null; // Allows reading a single document by ID
      allow list: if request.auth != null; // Allows querying the collection
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    // Daily Achievements:
    // Users can create/update their own achievements
    // Admins/Managers/TeamLeaders can read/write all achievements within their scope (more complex, for now allow all auth users to write)
    match /dailyAchievements/{achievementId} {
      allow read: if request.auth != null; // Could be more specific based on pod/competition
      allow create: if request.auth != null && request.resource.data.agentId == request.auth.uid; // Agent can create their own
      allow update: if request.auth != null && resource.data.agentId == request.auth.uid; // Agent can update their own
      // Admins can manage all achievements
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    // Daily Pod Targets:
    match /dailyPodTargets/{targetDocId} {
       allow read: if request.auth != null;
       // Allow write for admins or pod managers
       allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin','podManager']);
    }
  }
}
