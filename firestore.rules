
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Publicly Readable Collections ---
    // These collections are needed for public leaderboards, APIs, and general app function.
    // Writes are still restricted.
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if request.auth != null; // Only logged-in users (admins via app) can write
    }

    match /pods/{podId} {
      allow read: if true;
      allow write: if request.auth != null; // Only logged-in users (admins via app) can write
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId; // Users can update their own profile
      allow delete: if request.auth != null; // Admins delete via app
    }
    
    match /competitions/{competitionId} {
        allow read: if true;
        allow write: if request.auth != null; // Admins create/update through app
    }
    
    match /dailyPodTargets/{targetId} {
        allow read: if true;
        allow write: if request.auth != null; // Admins create/update through app
    }
    
    match /dailyAchievements/{achievementId} {
        allow read: if true;
        // Authenticated users can log their own achievements
        allow create, update, delete: if request.auth != null && request.auth.uid == request.resource.data.agentId;
    }
    
    match /dailyTaskLogs/{logId} {
        allow read: if true;
         // Authenticated users can log their own tasks
        allow create, delete: if request.auth != null && request.auth.uid == request.resource.data.agentId;
    }
    
    match /teamBonusLogs/{logId} {
        allow read: if true;
        // Allow authenticated users (admins) to create bonus logs
        allow create, update, delete: if request.auth != null;
    }

    match /rpsGames/{gameId} {
        // Allow anyone to create (play) and read game results
        allow read, create: if true;
        allow update, delete: if request.auth != null; // Only logged-in users can potentially delete
    }

    // --- General Write Rules for Authenticated Users ---
    // This rule allows any authenticated user to write to any document.
    // In a production environment with more granular security needs,
    // you would replace this with more specific rules. For the current app structure,
    // where admin actions are filtered through the UI, this is a safe starting point.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
