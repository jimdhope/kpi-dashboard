
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read and write access to the rpsGames collection for the game
    match /rpsGames/{gameId} {
      allow read, write: if true;
    }

    // Allow public read access to the pods collection for the API
    match /pods/{podId} {
      allow read: if true;
    }

    // Allow public read on achievements for leaderboards, but only authenticated writes
    match /dailyAchievements/{achievementId} {
        allow read: if true;
        allow write: if request.auth != null;
    }

    // Allow public read on competitions for context
    match /competitions/{competitionId} {
      allow read: if true;
    }

    // The general catch-all rule: all other documents require authentication.
    // This MUST be the last rule in this block to avoid overriding specific rules.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
