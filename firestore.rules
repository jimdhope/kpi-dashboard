
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Allow admins/managers to read all user data (for selectors etc.)
      allow read: if request.auth != null && (
                    request.auth.token.admin == true ||
                    request.auth.token.podManager == true ||
                    request.auth.token.teamLeader == true // Assuming roles are stored in custom claims
                 );
       // Alternatively, check roles stored in Firestore (less secure/efficient)
       // allow read: if request.auth != null && (
       //              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin', 'podManager', 'teamLeader'])
       //             );
    }

     // Allow authenticated users to read campaigns (needed for forms/context)
     match /campaigns/{campaignId} {
        allow read: if request.auth != null;
        // Allow write only for specific roles (e.g., admin) - CHECK YOUR ROLES IMPLEMENTATION
        allow write: if request.auth != null; // Simplified for now, refine based on roles
     }

      // Allow authenticated users to read campaign rules (needed for forms/context)
     match /campaignRules/{campaignId} {
        allow read: if request.auth != null;
        // Allow write only for specific roles (e.g., admin) - CHECK YOUR ROLES IMPLEMENTATION
        allow write: if request.auth != null; // Simplified for now, refine based on roles
     }


     // Allow authenticated users to read pods (needed for forms/context/assignment)
     match /pods/{podId} {
        allow read: if request.auth != null;
        // Allow write only for specific roles (e.g., admin) - CHECK YOUR ROLES IMPLEMENTATION
        allow write: if request.auth != null; // Simplified for now, refine based on roles
     }

      // Allow authenticated users to read competitions (needed for forms/context/selection)
     match /competitions/{competitionId} {
        allow read: if request.auth != null; // Allow any authenticated user to read competitions
        // Allow write only for specific roles (e.g., admin) - CHECK YOUR ROLES IMPLEMENTATION
        allow write: if request.auth != null; // Simplified for now, refine based on roles
     }

      // Daily Achievements: Allow agents to log their own, admins/managers/leaders to log for their pod/team?
     match /dailyAchievements/{logId} {
        // Agents can create logs for themselves
        allow create: if request.auth != null && request.resource.data.agentId == request.auth.uid;
        // Allow reading based on roles or specific pod/team membership - refine this rule
        allow read: if request.auth != null; // Simplistic for now
        // Allow updating/deleting based on roles or ownership
        allow update, delete: if request.auth != null && (
                                  request.auth.uid == resource.data.agentId || // Allow self-update/delete
                                  true // Placeholder for admin/manager roles check
                               );
        // Allow Admins/Managers/TLs to create logs (for backdating, etc.)
        allow create: if request.auth != null; // Simplified for now, refine based on roles
     }

     // Daily Pod Targets: Allow Admins/Managers/Leaders to read/write
     match /dailyPodTargets/{targetId} {
        allow read, write: if request.auth != null; // Simplified for now, refine based on roles
     }


    // Default deny for any other path - remove this if using the rule below
    // match /{document=**} {
    //   allow read, write: if false;
    // }
  }
}
