
{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  },
  "hosting": {
    "site": "kpi-quest",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "apphostingDeployMetadata": {
      "versionName": "v1",
      "serviceAccountEmail": "your-service-account@your-project.iam.gserviceaccount.com"
    },
    "spec": {
      "maxInstances": 10,
      "cpu": 1,
      "memory": "512Mi"
    }
  }
}
